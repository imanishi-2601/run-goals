<h1>コミュニティ新規作成</h1>
<% if @community.errors.any? %>
  <div class="error-messages">
    <ul>
      <% @community.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @community, local: true do |f| %>
  <div>
    <%= f.label :name, "名前" %> <span class="text-danger">*</span>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :introduction, "紹介文" %> <span class="text-danger">*</span>
    <%= f.text_field :introduction %>
  </div>
  <br>
  <%= f.submit "作成する", class: "btn btn-primary px-4" %>
  <%= link_to "戻る", communities_path, class: "btn btn-primary px-4" %>

<% end %>