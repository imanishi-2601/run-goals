<%= form_with url: search_path, method: :get, local: true, id: "search-form" do |f| %>
  <%= f.text_field :keyword, placeholder: "キーワード検索", id: "search-keyword" %>

  <%# 検索方法のセレクトボックス %>
  <%= f.select :match,
    options_for_select(
      [["部分一致", "partial"], ["完全一致", "exact"], ["前方一致", "prefix"], ["後方一致", "suffix"]],
      params[:match] || "partial"
    )
  %>

  <%= f.submit "検索" %>

  <% if params[:keyword].present? %>
    <%= link_to "クリア", search_path %>
  <% end %>

  <%# 検索時エラーメッセージ表示用の要素 %>
  <div id="search-error-box" class="search-error-box d-none">
    <p class="search-error-title">入力内容に誤りがあります。ご確認ください。</p>
    <ul class="mb-0">
      <li id="search-error"></li>
    </ul>
  </div>
<% end %>