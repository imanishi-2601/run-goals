        <div>
        <div class="post-container">
          <table class="post-table">
            <thead>
            <tr>
              <th>日付</th>
              <th>名前</th>
              <th>距離[km]</th>
              <th>時間[時:分:秒]</th>
              <th>ペース[分:秒/km]</th>
              <th></th>
            </tr>
            </thead>

            <tbody>
              <% if posts.any? %>
              <% posts.each do |post| %>
              <tr>
                <td><%= post.date %></td>
                <td><%= post.user.name %></td>
                <td><%= post.distance %></td>
                <td><%= post.formatted_time %></td>
                <td><%= post.formatted_pace %></td>
                <td>
                  <%= link_to "詳細", post_path(post) %>
                </td>
              </tr>
              <% end %>

              <% else %>
                <tr>
                  <td colspan="6">投稿がまだありません</td>
                </tr>
              <% end %>

            </tbody>
          </table>
        </div>
        </div>