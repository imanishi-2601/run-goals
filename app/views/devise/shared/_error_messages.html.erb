<% if resource.errors.any? %>
  <div class="form-errors">
    <p class="form-errors__title">
      入力内容に誤りがあります。ご確認ください。
    </p>

    <ul class="form-errors__list">
      <% [:name, :email, :password, :password_confirmation].each do |attr| %>
        <% resource.errors.full_messages_for(attr).each do |message| %>
          <li><%= message %></li>
        <% end %>
      <% end %>
    </ul>
  </div>
<% end %>