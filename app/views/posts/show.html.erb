<h1>投稿詳細</h1>

<div>
  <div class="post-container">
    <table class="post-table">
      <thead>
        <tr>
          <th class="col-date">日付</th>
          <th class="col-name">名前</th>
          <th class="col-distance">距離[km]</th>
          <th class="col-time">時間[時:分:秒]</th>
          <th class="col-pace">ペース[分:秒/km]</th>
          <th class="col-memo">メモ・感想</th>
          <th class="col-action"></th>
          <th class="col-action"></th>
        </tr>
      </thead>

      <tbody>
        <tr>
          <td class="col-date"><%= @post.date %></td>
          <td class="col-name"><%= link_to @post.user.name, user_path(@post.user) %></td>
          <td class="col-distance"><%= @post.distance %></td>
          <td class="col-time"><%= @post.formatted_time %></td>
          <td class="col-pace"><%= @post.formatted_pace %></td>
          <td class="col-memo"><%= @post.memo %></td>
          <td class="col-action"><%= link_to "編集", edit_community_post_path(@post) %></td>
          <td class="col-action">
            <%= link_to "削除", post_path(@post), data: { turbo_method: :delete, turbo_confirm: "削除しますか？" } %>
          </td>
        </tr>
      </tbody>
    </table>
    <br>
    <%= link_to "一覧へ戻る", posts_path(@post) %>
  </div>
</div>