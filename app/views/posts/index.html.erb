<% if @community.present? %>
  <h1><%= @community.name %>の投稿一覧</h1>
<% else %>
  <h1>全投稿一覧</h1>
<% end %>

<div>
  <div class="post-container">
    <div class="alert alert-warning">
      このコミュニティの投稿は一部のみ表示しています（全件閲覧には参加が必要です）。
        <%= link_to "コミュニティに参加する", community_path(@community), class: "btn btn-sm btn-primary ms-2" %>
    </div>
    <table class="post-table">
      <thead>
        <tr>
          <th class="col-date">日付</th>
          <th class="col-name">ユーザー名</th>
          <th class="col-distance">距離[km]</th>
          <th class="col-time">時間[時:分:秒]</th>
          <th class="col-pace">ペース[分:秒/km]</th>
          <th class="col-action"></th>
        </tr>
      </thead>

      <tbody>
        <% if @posts.any? %>
          <% @posts.each do |post| %>
            <tr>
              <td class="col-date"><%= post.date %></td>
              <td class="col-name"><%= post.user.name %></td>
              <td class="col-distance"><%= post.distance %></td>
              <td class="col-time"><%= post.formatted_time %></td>
              <td class="col-pace"><%= post.formatted_pace %></td>
              <td class="col-action">
                <%= link_to "詳細", post_path(post) %>
              </td>
            </tr>
          <% end %>

        <% else %>
          <tr>
            <td colspan="6">投稿がまだありません</td>
          </tr>
        <% end %>

      </tbody>
    </table>
    <br>
    <% if @community.present? %>
      <%= link_to "コミュニティ詳細へ戻る", community_path(@community), class: "btn-common" %>
    <% else %>
      <%= link_to "コミュニティ一覧へ戻る", communities_path, class: "btn-common" %>
    <% end %>
  </div>
</div>